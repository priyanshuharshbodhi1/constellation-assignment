# Copy to .env and edit as needed.
# All values shown are the defaults.

# Constellation group name — must match the --group flag on your satellites
CONSTELLATION_GROUP=constellation

# Restrict discovery to a specific network interface (optional)
# CONSTELLATION_INTERFACE=127.0.0.1

LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# How often (seconds) the bridge polls heartbeat states for changes
POLL_INTERVAL=0.5
